---
import type { Video } from '@/types/videoTypes'

interface Props {
  prev: Video | null
  next: Video | null
}

const { prev, next } = Astro.props
---

<nav class="video-nav" aria-label="前後の動画">
  <div class="video-nav__inner">
    {prev ? (
      <a href={`/archive/${prev.id}`} class="video-nav__link video-nav__link--prev">
        <span class="video-nav__label font-en">Prev</span>
        <span class="video-nav__title">{prev.title}</span>
      </a>
    ) : <div />}
    {next ? (
      <a href={`/archive/${next.id}`} class="video-nav__link video-nav__link--next">
        <span class="video-nav__label font-en">Next</span>
        <span class="video-nav__title">{next.title}</span>
      </a>
    ) : <div />}
  </div>
  <div class="video-nav__back">
    <a href="/archive" class="video-nav__back-link">一覧に戻る</a>
  </div>
</nav>

<style>
  @layer components {
    .video-nav {
      margin-top: 48px;
      padding-top: 32px;
      border-top: 1px solid var(--color_grey);
    }
    .video-nav__inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
    .video-nav__link {
      display: block;
      padding: 16px;
      border-radius: 8px;
      transition: background-color var(--transition_hover);
    }
    @media (--hover) {
      .video-nav__link:hover {
        background-color: rgba(0, 100, 255, 0.04);
      }
    }
    .video-nav__link--next {
      text-align: right;
    }
    .video-nav__label {
      font-size: rem(12);
      color: var(--color_dark_grey);
      text-transform: uppercase;
      display: block;
    }
    .video-nav__title {
      font-size: rem(14);
      font-weight: 600;
      line-height: 1.5;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
      overflow: hidden;
      margin-top: 4px;
    }
    .video-nav__back {
      text-align: center;
      margin-top: 32px;
    }
    .video-nav__back-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 290px;
      min-height: 62px;
      padding: 6px 24px;
      border: 1px solid var(--color_primary);
      border-radius: 9999px;
      background-color: var(--color_primary);
      color: var(--color_white);
      font-size: rem(18);
      font-weight: 700;
      transition: background-color var(--transition_hover), color var(--transition_hover);
    }
    @media (--hover) {
      .video-nav__back-link:hover {
        background-color: var(--color_bg_white);
        color: var(--color_primary);
      }
    }
    @media (--sp) {
      .video-nav__inner {
        grid-template-columns: 1fr;
        gap: 16px;
      }
      .video-nav__link--next {
        text-align: left;
      }
      .video-nav__back-link {
        min-width: auto;
        width: stretch;
        min-height: 58px;
        font-size: rem(16);
      }
    }
  }
</style>
