---
import type { Video } from '@/types/videoTypes'

interface Props {
  video: Video
}

const { video } = Astro.props
const thumbnailUrl = `/images/archive/thumbnails/${video.thumbnail}`
---

<a href={`/archive/${video.id}`} class="video-card" data-track={video.track}>
  <div class="video-card__thumbnail">
    <img
      src={thumbnailUrl}
      alt={`${video.title} のサムネイル`}
      loading="lazy"
      decoding="async"
      width="640"
      height="360"
    />
    <span class="video-card__duration font-en">{video.duration}</span>
  </div>
  <div class="video-card__body">
    <span class="video-card__track font-en">{video.track.toUpperCase()}</span>
    <h3 class="video-card__title">{video.title}</h3>
    <p class="video-card__speaker">
      {video.speaker}<span class="video-card__affiliation">（{video.speakerAffiliation}）</span>
    </p>
  </div>
</a>

<style>
  @layer components {
    .video-card {
      display: block;
      background-color: #fff;
      border-radius: 8px;
      overflow: hidden;
      transition: outline-color var(--transition_hover), box-shadow var(--transition_hover);
      outline: 2px solid transparent;
    }
    @media (--hover) {
      .video-card:hover,
      .video-card:focus-visible {
        outline-color: var(--color_primary);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
      }
    }
    .video-card__thumbnail {
      position: relative;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      background-color: var(--color_grey);
    }
    .video-card__thumbnail img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .video-card__duration {
      position: absolute;
      bottom: 8px;
      right: 8px;
      background-color: rgba(0, 0, 0, 0.75);
      color: var(--color_white);
      font-size: rem(12);
      padding: 2px 6px;
      border-radius: 4px;
      letter-spacing: 0.02em;
    }
    .video-card__body {
      padding: 16px;
      display: grid;
      row-gap: 8px;
    }
    .video-card__track {
      font-size: rem(12);
      color: var(--color_primary);
      font-weight: 500;
      text-transform: uppercase;
    }
    .video-card__title {
      font-family: var(--font_ja_bold);
      font-size: rem(16);
      font-weight: 600;
      line-height: 1.5;
      letter-spacing: 0.04em;
      overflow: hidden;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }
    .video-card__speaker {
      font-size: rem(14);
      color: var(--color_dark_grey);
      line-height: 1.5;
    }
    .video-card__affiliation {
      font-size: rem(12);
      color: var(--color_text_light_grey);
    }
    @media (--sp) {
      .video-card__body {
        padding: 12px;
      }
      .video-card__title {
        font-size: rem(14);
      }
    }
  }
</style>
