---
interface Props {
  videoPath: string
  title: string
}

const { videoPath, title } = Astro.props
const videoSrc = `/video/${videoPath}`
---

<div class="video-player">
  <div class="video-player__wrapper">
    <video
      src={videoSrc}
      controls
      controlsList="nodownload"
      preload="metadata"
      playsinline
    >
      <p>お使いのブラウザは動画の再生に対応していません。</p>
    </video>
  </div>
</div>

<style>
  @layer components {
    .video-player {
      margin-bottom: 32px;
    }
    .video-player__wrapper {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: 8px;
      overflow: hidden;
      background-color: var(--color_black);
    }
    .video-player__wrapper video {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }
  }
</style>
