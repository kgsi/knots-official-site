---
interface Props {
  videoPath: string
  title: string
  driveFileId: string
}

const { videoPath, title, driveFileId } = Astro.props
const videoSrc = `/video/${videoPath}`
const fallbackSrc = `https://drive.google.com/file/d/${driveFileId}/preview`
---

<div class="video-player">
  <div class="video-player__wrapper">
    <video
      src={videoSrc}
      controls
      controlsList="nodownload"
      preload="metadata"
      playsinline
    >
      <p>お使いのブラウザは動画の再生に対応していません。</p>
    </video>
  </div>
  <p class="video-player__note">
    再生できない場合は<a href={fallbackSrc} target="_blank" rel="noopener noreferrer" class="video-player__fallback">こちら（Google Drive）</a>からご視聴ください。
  </p>
</div>

<style>
  @layer components {
    .video-player {
      margin-bottom: 32px;
    }
    .video-player__wrapper {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: 8px;
      overflow: hidden;
      background-color: var(--color_black);
    }
    .video-player__wrapper video {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }
    .video-player__note {
      margin-top: 8px;
      font-size: rem(12);
      color: var(--color_dark_grey);
    }
    .video-player__fallback {
      color: var(--color_primary);
      text-decoration: underline;
      transition: opacity var(--transition_hover);
    }
    @media (--hover) {
      .video-player__fallback:hover {
        opacity: 0.7;
      }
    }
  }
</style>
