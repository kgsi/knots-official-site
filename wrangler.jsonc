{
  "name": "knots-official-site",
  "compatibility_date": "2025-08-02",
  "main": "./worker/index.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": ["/2026/archive", "/2026/archive/*", "/video/*"]
  },
  "r2_buckets": [
    {
      "binding": "VIDEOS",
      "bucket_name": "knots-videos-2026"
    }
  ]
}
